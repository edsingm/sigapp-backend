APP_NAME=SIGAPP
APP_ENV=local
APP_KEY=base64:Oc/kU+xPpv1XT2iQWvzfj3m3/kXlfLRJFE1ard9ByNg=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_DOMAIN=sigapp.com.br
CENTRAL_DOMAINS=localhost,127.0.0.1,sigapp.com.br,sigapp-backend

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Central Database (PostgreSQL)
DB_CONNECTION=central
DB_HOST=database
DB_PORT=
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_SSLMODE=prefer
TENANCY_CENTRAL_CONNECTION=central
TENANCY_TEMPLATE_TENANT_CONNECTION=tenant_template
TENANCY_HOST_CONNECTION=tenant_host_connection
TENANCY_TEMPLATE_SEARCH_PATH=public
TENANCY_HOST_SEARCH_PATH=public

# Session & Cache
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync  # use "redis" in production

# iniciar servico redis localmente * brew services start redis *
CACHE_STORE=redis

# Redis (for tenant caching and rate limiting)
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Resend Mail
MAIL_MAILER=failover
RESEND_API_KEY=
MAIL_FROM_ADDRESS="noreply@sigapp.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# Stripe
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
CASHIER_CURRENCY=brl

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost:8080,localhost:3000,sigapp.test,*.sigapp.test

# CORS (Next.js frontend)
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# Tenancy
TENANCY_DATABASE_PREFIX=tenant_
CASHIER_MODEL=App\Models\Central\Tenant

FRONTEND_URL=http://localhost:8080

TELESCOPE_ENABLED=false  # enable only in local/staging

AI_PROVIDER=openrouter
GEMINI_API_KEY=
#AI_GEMINI_AGENT_MODEL=gemini-2.5-flash-native-audio-dialog
OPENROUTER_API_KEY=

CENTRAL_ADMIN_NAME=
CENTRAL_ADMIN_EMAIL=
CENTRAL_ADMIN_PASSWORD=

CASHIER_PAYMENT_NOTIFICATION=App\Notifications\PaymentRequiresActionNotification
